---
interface Props {
	href: string;
	label: string;
}

const { href, label } = Astro.props;
---

<a href={href} class="back-link">← {label}</a>

<style>
	.back-link {
		display: inline-block;
		font-size: 0.9rem;
		font-weight: 700;
		color: rgb(var(--gray));
		text-decoration: none;
		margin-bottom: 1.25rem;
	}

	.back-link:hover {
		color: var(--accent);
	}
</style>
