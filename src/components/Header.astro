---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE, RESUME } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/#experience">Experience</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/#publications">Publications</HeaderLink>
			<HeaderLink href="/#skills">Tech Stack</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/#contact">Contact</HeaderLink>
			<a href={RESUME.url} class="resume-link" target="_blank" rel="noopener noreferrer">
				{RESUME.label}
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		gap: 1rem;
	}
	.internal-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.1rem;
	}
	nav a {
		padding: 1em 0.45em;
		color: rgb(var(--gray-dark));
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-size: 0.9rem;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.resume-link {
		margin-left: 0.35rem;
		padding: 0.4rem 0.8rem !important;
		border: 2px solid var(--accent) !important;
		border-radius: 8px;
		color: var(--accent) !important;
		font-weight: 700;
		font-size: 0.85rem !important;
		border-bottom: 2px solid var(--accent) !important;
		transition: background 0.2s, color 0.2s;
	}
	.resume-link:hover {
		background: var(--accent);
		color: #fff !important;
	}
	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			align-items: flex-start;
			padding: 0.5rem 0;
		}
		.internal-links {
			justify-content: flex-start;
		}
		nav a {
			padding: 0.45rem 0.45rem 0.45rem 0;
		}
	}
</style>
