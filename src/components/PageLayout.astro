---
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import BackLink from './BackLink.astro';

interface Props {
	title: string;
	description: string;
	image?: string;
	backHref?: string;
	backLabel?: string;
}

const { title, description, image, backHref, backLabel } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		<Header />
		<main>
			{backHref && backLabel && (
				<div class="page-back">
					<BackLink href={backHref} label={backLabel} />
				</div>
			)}
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-back {
		margin-bottom: -0.5rem;
	}
</style>
