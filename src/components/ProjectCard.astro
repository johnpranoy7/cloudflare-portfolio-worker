---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, techStack, githubUrl, liveUrl, additionalGithubUrls } = project.data;
const href = `/projects/${project.id}/`;
const hasSecondaryLinks = githubUrl || additionalGithubUrls?.length;
---

<article class="project-card">
	<div class="card-badges">
		{liveUrl ? (
			<span class="badge badge-demo">Live Demo Available</span>
		) : (
			<span class="badge badge-study">Case Study</span>
		)}
	</div>
	<a href={href} class="card-link">
		<div class="card-header">
			<h3>{title}</h3>
			<span class="arrow" aria-hidden="true">→</span>
		</div>
		<p class="card-description">{description}</p>
	</a>
	<div class="card-tags">
		{techStack.map((tech) => <span class="tag">{tech}</span>)}
	</div>
	{(liveUrl || hasSecondaryLinks) && (
		<div class="card-actions">
			{liveUrl ? (
				<a href={liveUrl} target="_blank" rel="noopener noreferrer" class="btn-demo">
					Try Demo →
				</a>
			) : (
				githubUrl && (
					<a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn-demo btn-outline">
						View Code →
					</a>
				)
			)}
			{hasSecondaryLinks && (liveUrl || additionalGithubUrls?.length) && (
				<div class="secondary-links">
					{liveUrl && githubUrl && (
						<a href={githubUrl} target="_blank" rel="noopener noreferrer" class="secondary-link">
							Code
						</a>
					)}
					{additionalGithubUrls?.map((repo) => (
						<a
							href={repo.url}
							class="secondary-link"
							{...(repo.url.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
						>
							{repo.label}
						</a>
					))}
				</div>
			)}
		</div>
	)}
</article>

<style>
	.project-card {
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		padding: 1.5rem;
		transition: box-shadow 0.2s, border-color 0.2s;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-width: 0;
	}

	.project-card:hover {
		box-shadow: var(--box-shadow);
		border-color: rgba(var(--accent-rgb), 0.3);
	}

	.card-badges {
		display: flex;
		gap: 0.4rem;
	}

	.badge {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		padding: 0.2rem 0.65rem;
		border-radius: 999px;
	}

	.badge-demo {
		background: rgba(var(--accent-rgb), 0.12);
		color: var(--accent-dark);
	}

	.badge-study {
		background: rgb(var(--gray-light));
		color: rgb(var(--gray));
	}

	.card-link {
		text-decoration: none;
		color: inherit;
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.5rem;
	}

	.card-header h3 {
		font-size: 1.25rem;
		margin: 0;
		color: rgb(var(--black));
	}

	.arrow {
		color: var(--accent);
		font-size: 1.25rem;
		opacity: 0;
		transition: opacity 0.2s, transform 0.2s;
	}

	.project-card:hover .arrow {
		opacity: 1;
		transform: translateX(4px);
	}

	.card-description {
		margin: 0.5rem 0 0;
		font-size: 0.95rem;
		color: rgb(var(--gray));
		line-height: 1.5;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.tag {
		font-size: 0.75rem;
		font-weight: 700;
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		background: rgba(var(--accent-rgb), 0.08);
		color: var(--accent-dark);
	}

	.card-actions {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		margin-top: auto;
		padding-top: 0.75rem;
		border-top: 1px solid rgb(var(--gray-light));
		width: 100%;
		min-width: 0;
	}

	.btn-demo {
		display: block;
		box-sizing: border-box;
		width: 100%;
		max-width: 100%;
		padding: 0.75rem 1rem;
		border-radius: 8px;
		background: var(--accent);
		color: #fff;
		font-size: 1rem;
		font-weight: 700;
		text-align: center;
		text-decoration: none;
		border: 2px solid transparent;
		transition: background 0.2s, transform 0.15s;
	}

	.btn-demo:hover {
		background: var(--accent-dark);
		color: #fff;
		transform: translateY(-1px);
	}

	.btn-outline {
		background: transparent;
		color: var(--accent);
		border-color: var(--accent);
	}

	.btn-outline:hover {
		background: var(--accent);
		color: #fff;
	}

	.secondary-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem 1rem;
	}

	.secondary-link {
		font-size: 0.9rem;
		font-weight: 700;
		text-decoration: none;
		color: var(--accent);
	}

	.secondary-link:hover {
		text-decoration: underline;
	}
</style>
