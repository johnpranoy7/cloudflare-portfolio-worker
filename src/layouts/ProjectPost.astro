---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import BackLink from '../components/BackLink.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: string;
	techStack: string[];
	githubUrl?: string;
	liveUrl?: string;
	additionalGithubUrls?: { label: string; url: string }[];
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	techStack,
	githubUrl,
	liveUrl,
	additionalGithubUrls,
} = Astro.props;

const hasLinks = githubUrl || liveUrl || additionalGithubUrls?.length;

function isExternal(url: string) {
	return url.startsWith('http://') || url.startsWith('https://');
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>
	<body>
		<Header />
		<main class="project-main">
			<article>
				{heroImage && (
					<div class="hero-image">
						<img width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="prose">
					<BackLink href="/projects" label="Back to projects" />
					<header class="project-header">
						<p class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<span class="last-updated">
										· Updated <FormattedDate date={updatedDate} />
									</span>
								)
							}
						</p>
						<h1>{title}</h1>
						<p class="lead">{description}</p>
						<div class="tech-stack">
							{techStack.map((tech) => <span class="tag">{tech}</span>)}
						</div>
						{hasLinks && (
							<div class="project-links">
								{liveUrl && (
									<a
										href={liveUrl}
										target="_blank"
										rel="noopener noreferrer"
										class="btn btn-primary btn-full"
									>
										Try Demo →
									</a>
								)}
								<div class="secondary-btns">
									{githubUrl && (
										<a
											href={githubUrl}
											target="_blank"
											rel="noopener noreferrer"
											class:list={['btn', liveUrl ? 'btn-secondary' : 'btn-primary']}
										>
											View Source
										</a>
									)}
									{additionalGithubUrls?.map((repo) => (
										<a
											href={repo.url}
											class="btn btn-secondary"
											{...(isExternal(repo.url)
												? { target: '_blank', rel: 'noopener noreferrer' }
												: {})}
										>
											{repo.label}
										</a>
									))}
								</div>
							</div>
						)}
						<hr />
					</header>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.project-main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	.hero-image img {
		display: block;
		width: 100%;
		max-height: 400px;
		object-fit: cover;
		border-radius: 0;
	}

	.prose {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 2em 1em 4em;
		color: rgb(var(--gray-dark));
	}

	.project-header {
		margin-bottom: 2rem;
	}

	.project-header h1 {
		margin: 0.25rem 0 0.75rem;
		font-size: 2.25rem;
	}

	.date {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}

	.last-updated {
		font-style: italic;
	}

	.lead {
		font-size: 1.15rem;
		color: rgb(var(--gray));
		margin-bottom: 1rem;
	}

	.tech-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1.25rem;
	}

	.tag {
		font-size: 0.8rem;
		font-weight: 700;
		padding: 0.25rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--accent-rgb), 0.08);
		color: var(--accent-dark);
	}

	.project-links {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.secondary-btns {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.btn {
		display: inline-block;
		box-sizing: border-box;
		padding: 0.55rem 1.2rem;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 700;
		text-decoration: none;
		text-align: center;
		transition: background 0.2s, color 0.2s, border-color 0.2s;
	}

	.btn-full {
		width: 100%;
		padding: 0.75rem 1.2rem;
		font-size: 1rem;
	}

	.btn-primary {
		background: var(--accent);
		color: rgb(var(--accent-text));
		border: 2px solid var(--accent);
	}

	.btn-primary:hover {
		background: var(--accent-dark);
		border-color: var(--accent-dark);
		color: rgb(var(--accent-text));
	}

	.btn-secondary {
		background: transparent;
		color: var(--accent);
		border: 2px solid var(--accent);
	}

	.btn-secondary:hover {
		background: var(--accent);
		color: rgb(var(--accent-text));
	}
</style>
