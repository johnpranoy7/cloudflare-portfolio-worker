---
import PageLayout from '../components/PageLayout.astro';
import { SITE_TITLE, PERSON, RESUME, CERTIFICATIONS } from '../consts';
---

<PageLayout
	title={`About | ${SITE_TITLE}`}
	description={`Learn more about ${PERSON.name} — background, education, and certifications.`}
>
	<header class="about-header">
		<h1>About Me</h1>
		<p class="subtitle">
			{PERSON.title} · {PERSON.experience} · {PERSON.location}
		</p>
		<p class="availability">{PERSON.availability}</p>
	</header>

	<div class="about-content">
		<section>
			<h2>Background</h2>
			<p>
				I started my career in enterprise software — five years at Evoke Technologies and Capgemini
				building banking and financial systems for clients like MUFG Union Bank. That work taught me
				how to ship reliable software under real constraints: legacy migrations, cross-time-zone
				collaboration, production observability, and the kind of testing discipline that keeps
				mission-critical systems running.
			</p>
			<p>
				Grad school at Kennesaw State pushed me in a different direction. As a Graduate Teaching and
				Research Assistant, I taught Python, built research tooling in Java, and explored the overlap
				between software engineering and AI — from fault localization algorithms to VR consumer
				behavior studies. I'm now looking for roles where I can combine that enterprise foundation
				with applied AI work.
			</p>
		</section>

		<section>
			<h2>Education</h2>
			<article class="info-card">
				<div class="card-meta">
					<time>Aug 2024 – May 2026</time>
				</div>
				<h3>M.S. Software Engineering</h3>
				<p class="org">Kennesaw State University · Marietta, GA</p>
				<p>
					Graduate Teaching Assistant for undergraduate Python programming. Graduate Research
					Assistant on spectrum-based fault localization and Unity VR consumer behavior research.
					Capstone: production-grade conversational AI with Spring AI, RAG, and tool-calling.
				</p>
			</article>
		</section>

		<section>
			<h2>Certifications</h2>
			<div class="card-grid">
				{
					CERTIFICATIONS.map((cert) => (
						<article class="info-card">
							<h3>{cert.name}</h3>
							<p class="org">{cert.issuer}</p>
							{cert.status && <p class="detail">{cert.status}</p>}
							{cert.certificateUrl && (
								<a
									href={cert.certificateUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="cert-link"
								>
									View certificate →
								</a>
							)}
						</article>
					))
				}
			</div>
		</section>

		<section class="links-section">
			<h2>Explore More</h2>
			<div class="link-cards">
				<a href="/#experience" class="link-card">Experience timeline</a>
				<a href="/projects" class="link-card">All projects</a>
				<a href="/#publications" class="link-card">Publications</a>
				<a href="/#skills" class="link-card">Tech stack</a>
				<a href={RESUME.url} class="link-card" target="_blank" rel="noopener noreferrer">
					Download resume
				</a>
			</div>
		</section>
	</div>
</PageLayout>

<style>
	.about-header {
		margin-bottom: 2.5rem;
	}

	.about-header h1 {
		font-size: 2.25rem;
		margin-bottom: 0.25rem;
	}

	.subtitle {
		color: rgb(var(--gray));
		font-size: 1.1rem;
		margin-bottom: 0.35rem;
	}

	.availability {
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--accent);
		margin: 0;
	}

	.about-content section {
		margin-bottom: 2.5rem;
	}

	.about-content h2 {
		font-size: 1.35rem;
		margin-bottom: 0.85rem;
		color: rgb(var(--black));
	}

	.about-content p {
		color: rgb(var(--gray-dark));
		line-height: 1.7;
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}

	.info-card {
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		padding: 1.25rem 1.5rem;
		transition: box-shadow 0.2s, border-color 0.2s;
	}

	.info-card:hover {
		box-shadow: var(--box-shadow);
		border-color: rgba(var(--accent-rgb), 0.3);
	}

	.card-meta time {
		font-size: 0.85rem;
		font-weight: 700;
		color: rgb(var(--gray));
	}

	.info-card h3 {
		font-size: 1.1rem;
		margin: 0.35rem 0 0.15rem;
		color: rgb(var(--black));
	}

	.org {
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--accent);
		margin: 0 0 0.65rem;
	}

	.info-card p:last-child {
		margin: 0;
		font-size: 0.95rem;
	}

	.detail {
		font-size: 0.9rem;
		color: rgb(var(--gray));
		margin: 0.25rem 0 0;
	}

	.cert-link {
		display: inline-block;
		margin-top: 0.65rem;
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
	}

	.cert-link:hover {
		text-decoration: underline;
	}

	.link-cards {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.link-card {
		display: inline-block;
		padding: 0.6rem 1.1rem;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 700;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		transition: box-shadow 0.2s, border-color 0.2s, color 0.2s;
	}

	.link-card:hover {
		box-shadow: var(--box-shadow);
		border-color: rgba(var(--accent-rgb), 0.3);
		color: var(--accent);
	}
</style>
