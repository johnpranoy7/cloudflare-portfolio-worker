---
import PageLayout from '../components/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Technologies from '../components/Technologies.astro';
import Publications from '../components/Publications.astro';
import Contact from '../components/Contact.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects
	.filter((p) => p.data.featured)
	.sort((a, b) => {
		const aDemo = a.data.liveUrl ? 1 : 0;
		const bDemo = b.data.liveUrl ? 1 : 0;
		if (bDemo !== aDemo) return bDemo - aDemo;
		return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
	});
const projectCount = allProjects.length;
const demoCount = allProjects.filter((p) => p.data.liveUrl).length;
---

<PageLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<Hero />

	<Experience />

	<section class="featured-projects">
		<div class="section-header">
			<h2>Featured Projects</h2>
			<a href="/projects" class="view-all">View all →</a>
		</div>
		<p class="section-subtitle">
			Highlighted work across AI, backend systems, and research — {demoCount} projects with live demos.
			<a href="/projects">View all {projectCount} →</a>
		</p>
		<div class="project-grid">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>
	</section>

	<Publications />

	<Technologies id="skills" />

	<Contact />
</PageLayout>

<style>
	.featured-projects {
		margin: 3rem 0;
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 0.35rem;
	}

	.section-header h2 {
		font-size: 1.75rem;
		margin: 0;
	}

	.section-subtitle {
		color: rgb(var(--gray));
		margin: 0 0 1.5rem;
	}

	.section-subtitle a {
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
	}

	.section-subtitle a:hover {
		text-decoration: underline;
	}

	.view-all {
		font-size: 0.95rem;
		font-weight: 700;
		text-decoration: none;
		color: var(--accent);
	}

	.view-all:hover {
		text-decoration: underline;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.25rem;
	}
</style>
